# ===========================================
# VERA - Variables de Entorno
# ===========================================
# Copia este archivo a .env y personaliza los valores
# NUNCA commitees el archivo .env real

# -------------------------------------------
# Base de Datos PostgreSQL
# -------------------------------------------
POSTGRES_USER=vera
POSTGRES_PASSWORD=tu-password-segura-aqui
POSTGRES_DB=vera_db
POSTGRES_PORT=5432

# -------------------------------------------
# Redis
# -------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# -------------------------------------------
# n8n
# -------------------------------------------
N8N_ENCRYPTION_KEY=tu-clave-de-32-caracteres-aqui
N8N_WEBHOOK_URL=https://tu-dominio.com
N8N_PORT=5678
N8N_USER=admin
N8N_PASSWORD=tu-password-admin

# -------------------------------------------
# API Keys
# Obtén tu API key en: https://console.groq.com/keys
GROQ_API_KEY=gsk_tu-api-key-de-groq

# Opcional: Para envío de emails
# Obtén tu API key en: https://resend.com/api-keys
RESEND_API_KEY=re_tu-api-key-de-resend

# -------------------------------------------
# Supabase (para n8n y backend)
# -------------------------------------------
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu-service-role-key

# -------------------------------------------
# Configuración de WhatsApp (Baileys)
# -------------------------------------------
BAILEYS_PORT=3006
BAILEYS_WEBHOOK_URL=http://n8n:5678/webhook/vera/whatsapp

# -------------------------------------------
# URLs de la Aplicación
# -------------------------------------------
APP_QR_BASE=https://tu-dominio.com/qr
APP_ACREDITACION_URL=https://tu-dominio.com
N8N_WEBHOOK_BASE=https://tu-dominio.com/webhook

# -------------------------------------------
# Web App (React)
# -------------------------------------------
WEB_APP_PORT=3000
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=tu-anon-key-publica
VITE_SUPABASE_PROJECT_ID=tu-project-id

# -------------------------------------------
# Zona Horaria
# -------------------------------------------
TZ=America/Bogota
GENERIC_TIMEZONE=America/Bogota
