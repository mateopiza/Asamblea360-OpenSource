# ===========================================
# App Web VERA - Variables de Entorno
# ===========================================
# Copia este archivo a .env y personaliza los valores

# Supabase Configuration
# Obtén estos valores de tu proyecto Supabase: https://app.supabase.com
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=tu-anon-key-publica
VITE_SUPABASE_PROJECT_ID=tu-project-id

# Configuración opcional
VITE_APP_NAME="VERA - Asamblea 360"
VITE_APP_URL=https://tu-dominio.com
